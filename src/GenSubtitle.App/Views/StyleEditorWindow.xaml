<Window x:Class="GenSubtitle.App.Views.StyleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="字幕样式编辑器" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🎨 字幕样式设置" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Style Properties -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Font Family -->
                <TextBlock Text="字体" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="FontFamilyComboBox" Margin="0,0,0,16">
                    <ComboBoxItem Content="Microsoft YaHei" IsSelected="True"/>
                    <ComboBoxItem Content="SimHei"/>
                    <ComboBoxItem Content="Arial"/>
                    <ComboBoxItem Content="Calibri"/>
                    <ComboBoxItem Content="Times New Roman"/>
                </ComboBox>

                <!-- Font Size -->
                <TextBlock Text="字号" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Slider x:Name="FontSizeSlider" Minimum="16" Maximum="48" Value="24" TickFrequency="2" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ElementName=FontSizeSlider, Path=Value, StringFormat={}{0:F0}}" HorizontalAlignment="Right" Margin="0,-24,0,16" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                <!-- Font Color -->
                <TextBlock Text="字体颜色" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="FontColorComboBox" Margin="0,0,0,16">
                    <ComboBoxItem Content="白色" Tag="#FFFFFF" IsSelected="True"/>
                    <ComboBoxItem Content="黄色" Tag="#FFFF00"/>
                    <ComboBoxItem Content="青色" Tag="#00FFFF"/>
                    <ComboBoxItem Content="黑色" Tag="#000000"/>
                </ComboBox>

                <!-- Position -->
                <TextBlock Text="位置" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="PositionComboBox" Margin="0,0,0,16">
                    <ComboBoxItem Content="底部居中" Tag="BottomCenter" IsSelected="True"/>
                    <ComboBoxItem Content="顶部居中" Tag="TopCenter"/>
                    <ComboBoxItem Content="中间居中" Tag="MiddleCenter"/>
                </ComboBox>

                <!-- Outline Width -->
                <TextBlock Text="描边宽度" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Slider x:Name="OutlineSlider" Minimum="0" Maximum="4" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,16"/>

                <!-- Background Opacity -->
                <TextBlock Text="背景透明度" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Slider x:Name="BackgroundOpacitySlider" Minimum="0" Maximum="100" Value="50" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ElementName=BackgroundOpacitySlider, Path=Value, StringFormat={}{0:F0}%}" HorizontalAlignment="Right" Margin="0,-24,0,16" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                <!-- Style Presets -->
                <TextBlock Text="样式预设" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="PresetComboBox" Margin="0,0,0,16" SelectionChanged="OnPresetSelected">
                    <ComboBoxItem Content="默认样式"/>
                    <ComboBoxItem Content="简洁白色"/>
                    <ComboBoxItem Content="醒目黄色"/>
                    <ComboBoxItem Content="电影风格"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80" Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="保存预设" Style="{StaticResource MaterialDesignOutlinedButton}" Width="90" Margin="0,0,8,0" Click="OnSavePreset"/>
            <Button Content="应用" Style="{StaticResource MaterialDesignRaisedButton}" Width="80" Click="OnApply"/>
        </StackPanel>
    </Grid>
</Window>
