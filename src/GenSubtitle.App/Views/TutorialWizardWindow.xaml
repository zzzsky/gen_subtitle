<Window x:Class="GenSubtitle.App.Views.TutorialWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="欢迎使用 GenSubtitle" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="TitleText" Text="欢迎使用 GenSubtitle" FontSize="24" FontWeight="Bold" Margin="0,0,0,24"/>

        <!-- Content Pages -->
        <Frame x:Name="WizardFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <!-- Footer with Navigation -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Progress Dots -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="Dot1" Width="12" Height="12" Fill="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,8,0"/>
                <Ellipse x:Name="Dot2" Width="12" Height="12" Fill="{DynamicResource MaterialDesignCheckBoxDisabled}" Margin="0,0,8,0"/>
                <Ellipse x:Name="Dot3" Width="12" Height="12" Fill="{DynamicResource MaterialDesignCheckBoxDisabled}" Margin="0,0,8,0"/>
                <Ellipse x:Name="Dot4" Width="12" Height="12" Fill="{DynamicResource MaterialDesignCheckBoxDisabled}"/>
            </StackPanel>

            <!-- Navigation Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BackButton" Content="上一步" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80" Margin="0,0,8,0" Click="OnBack" IsEnabled="False"/>
                <Button x:Name="NextButton" Content="下一步" Style="{StaticResource MaterialDesignRaisedButton}" Width="80" Click="OnNext"/>
                <Button x:Name="FinishButton" Content="完成" Style="{StaticResource MaterialDesignRaisedButton}" Width="80" Click="OnFinish" Visibility="Collapsed"/>
                <Button Content="跳过" Style="{StaticResource MaterialDesignOutlinedButton}" Width="80" Margin="8,0,0,0" Click="OnSkip"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
