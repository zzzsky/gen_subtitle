<Window x:Class="GenSubtitle.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings" Height="560" Width="600" WindowStartupLocation="CenterOwner">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" Margin="0,0,0,12" materialDesign:ElevationAssist.Elevation="Dp4">
      <DockPanel>
        <TextBlock Text="Settings" Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
        <TextBlock Text="  App configuration" Style="{StaticResource MaterialDesignBody1TextBlock}" Foreground="{DynamicResource MaterialDesignBodyLight}" />
      </DockPanel>
    </materialDesign:ColorZone>

    <materialDesign:Card Grid.Row="1" Margin="0,0,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="170" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="Whisper Model" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <ComboBox x:Name="WhisperModelBox" Grid.Row="0" Grid.Column="1" Margin="8,4" IsEditable="False" Style="{StaticResource MaterialDesignOutlinedComboBox}" />

        <TextBlock Text="Use GPU" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <CheckBox x:Name="UseGpuBox" Grid.Row="1" Grid.Column="1" Margin="8,4" Style="{StaticResource MaterialDesignCheckBox}" />

        <TextBlock Text="Qwen API Key" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <TextBox x:Name="QwenKeyBox" Grid.Row="2" Grid.Column="1" Margin="8,4" Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <TextBlock Text="Qwen Model" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <TextBox x:Name="QwenModelBox" Grid.Row="3" Grid.Column="1" Margin="8,4" Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <TextBlock Text="Auto Translate" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <CheckBox x:Name="AutoTranslateBox" Grid.Row="4" Grid.Column="1" Margin="8,4" Style="{StaticResource MaterialDesignCheckBox}" />

        <TextBlock Text="Max Concurrency" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <TextBox x:Name="MaxConcurrencyBox" Grid.Row="5" Grid.Column="1" Margin="8,4" Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <TextBlock Text="Enabled Languages" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
        <TextBox x:Name="LanguagesBox" Grid.Row="6" Grid.Column="1" Margin="8,4" Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
          <Button Width="90" Margin="0,0,8,0" Click="OnCancel" Style="{StaticResource MaterialDesignOutlinedButton}">Cancel</Button>
          <Button Width="90" Click="OnSave" Style="{StaticResource MaterialDesignRaisedButton}">Save</Button>
        </StackPanel>
      </Grid>
    </materialDesign:Card>
  </Grid>
</Window>
