<Window x:Class="GenSubtitle.App.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export" Height="260" Width="360" WindowStartupLocation="CenterOwner">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Background="{StaticResource VsHeaderBrush}" BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="1" Padding="10" CornerRadius="6">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Export" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Text="  Video options" Foreground="{StaticResource VsMutedTextBrush}" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,10,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <RadioButton x:Name="SoftMuxRadio" Content="Soft Mux" GroupName="ExportMode" Grid.Row="0" Margin="0,0,0,8" />
        <RadioButton x:Name="BurnInRadio" Content="Burn-in (Hard Subs)" GroupName="ExportMode" Grid.Row="1" Margin="0,0,0,8" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
          <TextBlock Text="ASS Style" VerticalAlignment="Center" Width="80" Foreground="{StaticResource VsMutedTextBrush}" />
          <TextBox x:Name="StyleBox" Width="200" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Width="90" Margin="0,0,8,0" Click="OnCancel">Cancel</Button>
          <Button Width="90" Style="{StaticResource PrimaryButton}" Click="OnSave">Export</Button>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
