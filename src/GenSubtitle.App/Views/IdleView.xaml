<UserControl x:Class="GenSubtitle.App.Views.IdleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GenSubtitle.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:IdleViewModel}"
             mc:Ignorable="d"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             Drop="OnDrop">
    <UserControl.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding ImportFilesCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:PackIcon Kind="Subtitles" Width="120" Height="120" Foreground="{DynamicResource MaterialDesignPrimaryHueMidBrush}" Margin="0,0,0,32"/>
            <TextBlock Text="{Binding WelcomeTitle}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,48"/>
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="2" CornerRadius="8" Padding="64" Background="{DynamicResource MaterialDesignCardBackground}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="FileUpload" Width="64" Height="64" Foreground="{DynamicResource MaterialDesignBodyLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="拖放视频文件到这里" FontSize="18" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLightBrush}"/>
                    <TextBlock Text="或点击按钮选择文件" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLightBrush}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
