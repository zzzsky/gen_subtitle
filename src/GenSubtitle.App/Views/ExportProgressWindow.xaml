<Window x:Class="GenSubtitle.App.Views.ExportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exporting" Height="220" Width="420" WindowStartupLocation="CenterOwner">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Exporting" FontSize="16" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="{Binding FileName}" Foreground="{StaticResource VsMutedTextBrush}" Margin="0,4,0,8" TextTrimming="CharacterEllipsis" />
    <ProgressBar Grid.Row="2" Height="12" Value="{Binding Progress}" Maximum="100" />
    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
      <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource VsMutedTextBrush}" />
      <TextBlock Text="  " />
      <TextBlock Text="{Binding EtaText}" Foreground="{StaticResource VsMutedTextBrush}" />
    </StackPanel>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Width="110" Margin="0,0,8,0" Content="Open Folder" Click="OnOpenFolder" IsEnabled="{Binding IsCompleted}" />
      <Button Width="90" Content="Close" Click="OnClose" IsEnabled="{Binding IsCompleted}" />
    </StackPanel>
  </Grid>
</Window>
